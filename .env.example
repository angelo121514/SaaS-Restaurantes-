# =====================================================
# CMOR FLOW — Variables de entorno (.env.example)
# =====================================================
# Copia este archivo a .env y rellena los valores.
# NO commitear .env (ya está en .gitignore).
# =====================================================

# ─── Supabase (obligatorio para producción) ───
# Obtener de: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── Sentry (monitoreo de errores) ───
# Obtener DSN de: https://sentry.io/settings/cmor-flow/projects/cmor-flow/keys/
VITE_SENTRY_DSN=
VITE_APP_VERSION=1.0.0

# ─── Resend (emails transaccionales para DSAR) ───
# Obtener de: https://resend.com/api-keys
# Usado por Edge Functions (NO lleva prefijo VITE_)
RESEND_API_KEY=

# ─── URL pública de la app (para links de verificación DSAR) ───
# En producción: https://app.cmorflow.cl
# En staging: https://cmor-flow-staging.vercel.app
# En local: http://localhost:5173
PUBLIC_APP_URL=http://localhost:5173

# ─── Tests (variables de test, no usar en producción) ───
# Para tests de integración contra Supabase local (supabase start)
VITE_TEST_SUPABASE_URL=http://127.0.0.1:54321
VITE_TEST_SUPABASE_ANON_KEY=
VITE_TEST_VERCEL_URL=

# Para tests E2E (credenciales de usuarios sembrados)
E2E_OWNER_EMAIL=owner@test.com
E2E_OWNER_PASSWORD=TestPassword123!
E2E_ADMIN_EMAIL=admin@test.com
E2E_ADMIN_PASSWORD=AdminPassword123!
E2E_RESTAURANT_SLUG=test-restaurant
E2E_BASE_URL=http://localhost:5173

# ─── Edge Functions (server-side, NO lleva prefijo VITE_) ───
# Estas variables se setean en Supabase Dashboard → Edge Functions → Environment Variables
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE=your_service_role_key
# SUPABASE_ANON_KEY=your_anon_key
# RESEND_API_KEY=re_xxxxx
# PUBLIC_APP_URL=https://app.cmorflow.cl

# =====================================================
# RECORDATORIOS:
# 1. Sin .env → la app arranca en MODO DEMO (datos en localStorage).
# 2. Con .env completo → conexión real a Supabase.
# 3. VITE_* se exponen al navegador (NO poner secrets aquí).
# 4. Variables de Edge Functions se setean en Supabase Dashboard.
# =====================================================
